const { run, get, all } = require('../index');
const { v4: uuidv4 }   = require('uuid');

const User = {

  // Create a new user — returns the new user's id
  async create({ email, password, name }) {
    const id = uuidv4();
    await run(
      `INSERT INTO users (id, email, password, name) VALUES (?, ?, ?, ?)`,
      [id, email, password, name]
    );
    return id;
  },

  // Find a user by email — used during login
  async findByEmail(email) {
    return get(`SELECT * FROM users WHERE email = ?`, [email]);
  },

  // Find a user by id — used by authGuard to validate token
  async findById(id) {
    return get(`SELECT id, email, name, created_at FROM users WHERE id = ?`, [id]);
  },

  // Save or update personal scan data for a user
  async saveData(user_id, { full_name, phone, city, dob }) {
    const existing = await get(`SELECT id FROM user_data WHERE user_id = ?`, [user_id]);
    if (existing) {
      await run(
        `UPDATE user_data SET full_name=?, phone=?, city=?, dob=?, updated_at=CURRENT_TIMESTAMP
         WHERE user_id=?`,
        [full_name, phone, city, dob, user_id]
      );
    } else {
      const id = uuidv4();
      await run(
        `INSERT INTO user_data (id, user_id, full_name, phone, city, dob) VALUES (?,?,?,?,?,?)`,
        [id, user_id, full_name, phone, city, dob]
      );
    }
  },

  // Get personal data for a user
  async getData(user_id) {
    return get(`SELECT * FROM user_data WHERE user_id = ?`, [user_id]);
  },

  // Delete a user and all their data (CASCADE handles related rows)
  async delete(id) {
    return run(`DELETE FROM users WHERE id = ?`, [id]);
  }

};

module.exports = User;