const { run, get, all } = require('../index');
const { v4: uuidv4 }   = require('uuid');

const Scan = {

  // Create a new scan run for a user
  async create(user_id) {
    const id = uuidv4();
    await run(
      `INSERT INTO scans (id, user_id, status) VALUES (?, ?, 'running')`,
      [id, user_id]
    );
    return id;
  },

  // Update scan progress — called as each source batch finishes
  async updateProgress(id, sources_checked) {
    return run(
      `UPDATE scans SET sources_checked = ? WHERE id = ?`,
      [sources_checked, id]
    );
  },

  // Mark a scan as complete with final risk score
  async complete(id, risk_score) {
    return run(
      `UPDATE scans SET status='complete', risk_score=?, finished_at=CURRENT_TIMESTAMP
       WHERE id=?`,
      [risk_score, id]
    );
  },

  // Mark a scan as failed
  async fail(id) {
    return run(
      `UPDATE scans SET status='failed', finished_at=CURRENT_TIMESTAMP WHERE id=?`,
      [id]
    );
  },

  // Get a single scan by id
  async getById(id) {
    return get(`SELECT * FROM scans WHERE id = ?`, [id]);
  },

  // Get the most recent scan for a user
  async getLatest(user_id) {
    return get(
      `SELECT * FROM scans WHERE user_id = ? ORDER BY started_at DESC LIMIT 1`,
      [user_id]
    );
  },

  // Get all scans for a user (history)
  async getByUser(user_id) {
    return all(
      `SELECT * FROM scans WHERE user_id = ? ORDER BY started_at DESC`,
      [user_id]
    );
  }

};

module.exports = Scan;