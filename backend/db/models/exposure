const { run, get, all } = require('../index');
const { v4: uuidv4 }   = require('uuid');

const Exposure = {

  // Insert a single exposure found during a scan
  async insert({ scan_id, user_id, source, data_found, severity, url }) {
    const id = uuidv4();
    await run(
      `INSERT INTO exposures (id, scan_id, user_id, source, data_found, severity, url)
       VALUES (?, ?, ?, ?, ?, ?, ?)`,
      [id, scan_id, user_id, source, data_found, severity, url || null]
    );
    return id;
  },

  // Insert multiple exposures at once
  async insertMany(exposures) {
    const ids = [];
    for (const exp of exposures) {
      const id = await Exposure.insert(exp);
      ids.push(id);
    }
    return ids;
  },

  // Get all exposures from a specific scan
  async getByScan(scan_id) {
    return all(
      `SELECT * FROM exposures WHERE scan_id = ? ORDER BY
       CASE severity WHEN 'high' THEN 1 WHEN 'medium' THEN 2 ELSE 3 END`,
      [scan_id]
    );
  },

  // Get all exposures for a user across all scans
  async getByUser(user_id) {
    return all(
      `SELECT e.*, s.started_at as scan_date
       FROM exposures e
       JOIN scans s ON e.scan_id = s.id
       WHERE e.user_id = ?
       ORDER BY e.found_at DESC`,
      [user_id]
    );
  },

  // Get a single exposure by id
  async getById(id) {
    return get(`SELECT * FROM exposures WHERE id = ?`, [id]);
  },

  // Update severity of an exposure
  async updateSeverity(id, severity) {
    return run(
      `UPDATE exposures SET severity = ? WHERE id = ?`,
      [severity, id]
    );
  },

  // Count exposures by severity for a user's latest scan
  async countBySeverity(scan_id) {
    return all(
      `SELECT severity, COUNT(*) as count FROM exposures
       WHERE scan_id = ? GROUP BY severity`,
      [scan_id]
    );
  }

};

module.exports = Exposure;